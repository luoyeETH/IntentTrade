# Copy to .env and fill in as needed

# LLM intent analysis (required — AI extracts symbols + entry/SL/TP)
# Anthropic-compatible endpoint (your own provider base URL)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=grok-4.5
INTENT_TRADE_LLM_MODEL=grok-4.5
# Optional: use a different native-vision model for direct image analysis.
INTENT_TRADE_VISION_MODEL=
INTENT_TRADE_LLM_TIMEOUT=90

# --- Free low-frequency X reads through bird CLI (cookie auth) ---
# Install: npm install -g @jtsang/bird@0.8.1
# From an active x.com browser session, copy cookies auth_token and ct0.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_BIRD_BIN=bird

# --- Recommended for current live run: RapidAPI Twttr API (twitter241) ---
# https://rapidapi.com/davethebeast/api/twitter241
# Then set config twitter.source: rapidapi
TWITTER_RAPIDAPI_KEY=
TWITTER_RAPIDAPI_HOST=twitter241.p.rapidapi.com

# Optional: twitterapi.io (third-party, cheap user timeline)
# Sign up https://twitterapi.io — ~$0.1 free credits, no credit card
TWITTERAPI_IO_KEY=

# Optional: Official X API pay-per-use (more expensive for reads)
X_BEARER_TOKEN=
# or OAuth 1.0a
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Data paths (defaults fine for local)
INTENT_TRADE_DB_PATH=data/db/intent_trade.db
INTENT_TRADE_CONFIG=config/settings.yaml

# Optional SOCKS/HTTP proxy for market data (e.g. Japan node when api.binance.com is 451)
# Prefer socks5h:// so DNS resolves on the proxy side.
# INTENT_TRADE_HTTP_PROXY=socks5h://user:pass@host:1080
# Falls back to HTTPS_PROXY / ALL_PROXY / HTTP_PROXY if unset.
